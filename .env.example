# ============================================================================
# ShopLite - exemple de configuration (DEV).
# Copier en .env puis adapter :  cp .env.example .env
# Ne JAMAIS commiter un vrai .env (voir .gitignore).
# ============================================================================

# --- Application -------------------------------------------------------------
NODE_ENV=development
API_PORT=3000            # port interne de l'API (dans le conteneur)
HTTP_PORT=8080           # port exposé par le proxy nginx (http://localhost:8080)
APP_VERSION=dev          # version affichée par l'API / le frontend
LOG_LEVEL=info           # DEBUG | INFO | WARN | ERROR | FATAL

# Incident contrôlé : "true" casse volontairement /api/products (démo rollback)
SIMULATE_INCIDENT=false

# --- Base de données ---------------------------------------------------------
POSTGRES_DB=shoplite
POSTGRES_USER=shoplite
# Valeur d'EXEMPLE non sensible : à remplacer par un secret fort en local/CI.
POSTGRES_PASSWORD=change_me_in_local_env
DB_PORT=55432            # port hôte pour atteindre postgres (debug local)

# Chaîne de connexion utilisée par l'API (le host `db` = nom du service Compose)
DATABASE_URL=postgres://shoplite:change_me_in_local_env@db:5432/shoplite
