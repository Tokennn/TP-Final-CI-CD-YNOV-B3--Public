# Exemple de configuration STAGING (copier en .env.staging).
NODE_ENV=staging
API_PORT=3000
HTTP_PORT=8081
DB_PORT=55433
APP_VERSION=staging
LOG_LEVEL=debug
SIMULATE_INCIDENT=false

POSTGRES_DB=shoplite_staging
POSTGRES_USER=shoplite_staging
POSTGRES_PASSWORD=change_me_staging_secret
DATABASE_URL=postgres://shoplite_staging:change_me_staging_secret@db:5432/shoplite_staging
