# Exemple de configuration PRODUCTION SIMULÉE (copier en .env.prod).
# En prod réelle, ces valeurs viennent de GitHub Secrets (environment "production").
NODE_ENV=production
API_PORT=3000
HTTP_PORT=8082
DB_PORT=55434
APP_VERSION=v1.0.0
LOG_LEVEL=info
SIMULATE_INCIDENT=false

POSTGRES_DB=shoplite_prod
POSTGRES_USER=shoplite_prod
POSTGRES_PASSWORD=change_me_prod_secret
DATABASE_URL=postgres://shoplite_prod:change_me_prod_secret@db:5432/shoplite_prod
